<!-- SKILLS SECTION -->
<section id="skills">
  <p class="section-label reveal">// 02 — Personal Skills Assessment</p>
  <h2 class="reveal">Know Your <em>Strengths</em></h2>

  <div class="skills-grid">
    <div class="card reveal">
      <p class="skill-category-title">Technical Skills (Current)</p>
      <div class="skill-bar-wrap">
