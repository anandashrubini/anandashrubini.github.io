<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Anandashrubini Seevagan | Cybersecurity Portfolio</title>
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg: #060a0f;
      --bg2: #0c1219;
      --bg3: #111a24;
      --accent: #00e5ff;
      --accent2: #ff4081;
      --accent3: #69ff47;
      --text: #e8f0f7;
      --muted: #7a9bb5;
      --border: rgba(0,229,255,0.15);
      --card: rgba(12,18,25,0.85);
      --glow: 0 0 30px rgba(0,229,255,0.15);
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Syne', sans-serif;
      line-height: 1.7;
      overflow-x: hidden;
    }

    /* === NOISE OVERLAY === */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 0;
    }

    /* === GRID BG === */
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(0,229,255,0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0,229,255,0.03) 1px, transparent 1px);
      background-size: 40px 40px;
      pointer-events: none;
      z-index: 0;
    }

    /* === NAV === */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      background: rgba(6,10,15,0.92);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 2.5rem;
      height: 64px;
    }
    .nav-logo {
      font-family: 'Space Mono', monospace;
      font-size: 0.85rem;
      color: var(--accent);
      letter-spacing: 0.1em;
      text-decoration: none;
    }
    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
    }
    .nav-links a {
      font-size: 0.78rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
      font-family: 'Space Mono', monospace;
    }
    .nav-links a:hover { color: var(--accent); }

    /* === HERO === */
    #hero {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 100px 2rem 4rem;
      position: relative;
      z-index: 1;
      text-align: center;
    }
    .hero-glow {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 600px;
      height: 600px;
      background: radial-gradient(circle, rgba(0,229,255,0.06) 0%, transparent 70%);
      pointer-events: none;
    }
    .tag-line {
      font-family: 'Space Mono', monospace;
      font-size: 0.75rem;
      letter-spacing: 0.25em;
      color: var(--accent);
      text-transform: uppercase;
      margin-bottom: 1.5rem;
      opacity: 0;
      animation: fadeUp 0.6s ease 0.2s forwards;
    }
    h1 {
      font-size: clamp(2.8rem, 7vw, 5.5rem);
      font-weight: 800;
      line-height: 1.05;
      letter-spacing: -0.02em;
      margin-bottom: 1rem;
      opacity: 0;
      animation: fadeUp 0.7s ease 0.4s forwards;
    }
    h1 span { color: var(--accent); }
    .hero-sub {
      font-size: 1.1rem;
      color: var(--muted);
      max-width: 560px;
      margin: 0 auto 2.5rem;
      opacity: 0;
      animation: fadeUp 0.7s ease 0.6s forwards;
    }
    .hero-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      justify-content: center;
      margin-bottom: 3rem;
      opacity: 0;
      animation: fadeUp 0.7s ease 0.8s forwards;
    }
    .badge {
      font-family: 'Space Mono', monospace;
      font-size: 0.72rem;
      padding: 0.4rem 1rem;
      border: 1px solid var(--border);
      border-radius: 2px;
      color: var(--accent);
      letter-spacing: 0.1em;
      background: rgba(0,229,255,0.04);
    }
    .cta-row {
      display: flex;
      gap: 1rem;
      justify-content: center;
      opacity: 0;
      animation: fadeUp 0.7s ease 1s forwards;
    }
    .btn {
      font-family: 'Space Mono', monospace;
      font-size: 0.78rem;
      letter-spacing: 0.1em;
      padding: 0.85rem 2rem;
      border-radius: 2px;
      text-decoration: none;
      transition: all 0.2s;
      text-transform: uppercase;
    }
    .btn-primary {
      background: var(--accent);
      color: var(--bg);
      border: 1px solid var(--accent);
    }
    .btn-primary:hover { background: transparent; color: var(--accent); }
    .btn-outline {
      border: 1px solid var(--border);
      color: var(--muted);
    }
    .btn-outline:hover { border-color: var(--accent); color: var(--accent); }

    /* === SECTIONS === */
    section {
      padding: 6rem 2rem;
      position: relative;
      z-index: 1;
      max-width: 1100px;
      margin: 0 auto;
    }
    .section-label {
      font-family: 'Space Mono', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.3em;
      color: var(--accent);
      text-transform: uppercase;
      margin-bottom: 0.75rem;
    }
    h2 {
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 800;
      letter-spacing: -0.02em;
      margin-bottom: 3rem;
      line-height: 1.1;
    }
    h2 em { font-style: normal; color: var(--accent); }

    /* === CARDS === */
    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 2rem;
      transition: border-color 0.3s, box-shadow 0.3s;
    }
    .card:hover {
      border-color: rgba(0,229,255,0.4);
      box-shadow: var(--glow);
    }

    /* === CAREER SECTION === */
    .career-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }
    .career-main {
      grid-column: 1 / -1;
      display: grid;
      grid-template-columns: 2fr 1fr;
      gap: 1.5rem;
      align-items: start;
    }
    .role-title {
      font-size: 1.4rem;
      font-weight: 700;
      color: var(--accent);
      margin-bottom: 1rem;
    }
    .role-body { color: var(--muted); font-size: 0.95rem; line-height: 1.8; }
    ul.skill-list { list-style: none; padding: 0; }
    ul.skill-list li {
      padding: 0.5rem 0;
      border-bottom: 1px solid var(--border);
      font-size: 0.88rem;
      color: var(--muted);
      display: flex;
      align-items: center;
      gap: 0.6rem;
    }
    ul.skill-list li::before { content: '▸'; color: var(--accent); font-size: 0.7rem; }
    .stat-card {
      text-align: center;
      padding: 1.5rem;
    }
    .stat-num {
      font-size: 2.5rem;
      font-weight: 800;
      color: var(--accent);
      font-family: 'Space Mono', monospace;
      line-height: 1;
    }
    .stat-label { font-size: 0.78rem; color: var(--muted); margin-top: 0.4rem; letter-spacing: 0.05em; }

    /* === SKILLS SECTION === */
    #skills { background: linear-gradient(to bottom, transparent, rgba(0,229,255,0.02), transparent); }
    .skills-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }
    .skill-category-title {
      font-size: 0.75rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent2);
      font-family: 'Space Mono', monospace;
      margin-bottom: 1.5rem;
    }
    .skill-bar-wrap { margin-bottom: 1.2rem; }
    .skill-bar-label {
      display: flex;
      justify-content: space-between;
      font-size: 0.82rem;
      margin-bottom: 0.4rem;
      color: var(--text);
    }
    .skill-bar-label span { color: var(--muted); font-family: 'Space Mono', monospace; font-size: 0.75rem; }
    .bar-track {
      height: 4px;
      background: rgba(255,255,255,0.06);
      border-radius: 2px;
      overflow: hidden;
    }
    .bar-fill {
      height: 100%;
      border-radius: 2px;
      background: linear-gradient(90deg, var(--accent), var(--accent3));
      width: 0;
      transition: width 1.2s cubic-bezier(0.4,0,0.2,1);
    }
    .soft-skill-tag {
      display: inline-block;
      margin: 0.3rem;
      padding: 0.45rem 1rem;
      font-size: 0.8rem;
      border: 1px solid var(--border);
      border-radius: 2px;
      color: var(--text);
      background: rgba(255,255,255,0.03);
    }
    .gap-table { width: 100%; border-collapse: collapse; font-size: 0.88rem; }
    .gap-table th {
      text-align: left;
      padding: 0.75rem 1rem;
      font-size: 0.72rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--muted);
      border-bottom: 1px solid var(--border);
      font-family: 'Space Mono', monospace;
    }
    .gap-table td {
      padding: 0.75rem 1rem;
      border-bottom: 1px solid rgba(255,255,255,0.04);
      color: var(--muted);
    }
    .gap-table td:first-child { color: var(--text); }
    .status { font-size: 0.72rem; padding: 0.25rem 0.6rem; border-radius: 2px; font-family: 'Space Mono', monospace; }
    .status.have { background: rgba(105,255,71,0.1); color: var(--accent3); border: 1px solid rgba(105,255,71,0.2); }
    .status.need { background: rgba(255,64,129,0.1); color: var(--accent2); border: 1px solid rgba(255,64,129,0.2); }
    .status.partial { background: rgba(0,229,255,0.1); color: var(--accent); border: 1px solid rgba(0,229,255,0.2); }

    /* === PLAN SECTION === */
    .timeline { position: relative; padding-left: 2rem; }
    .timeline::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0; bottom: 0;
      width: 1px;
      background: linear-gradient(to bottom, var(--accent), var(--accent2), transparent);
    }
    .timeline-item {
      position: relative;
      margin-bottom: 2.5rem;
      padding-left: 1.5rem;
    }
    .timeline-item::before {
      content: '';
      position: absolute;
      left: -2.4rem;
      top: 0.4rem;
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: var(--accent);
      border: 2px solid var(--bg);
      box-shadow: 0 0 10px var(--accent);
    }
    .timeline-year {
      font-family: 'Space Mono', monospace;
      font-size: 0.72rem;
      color: var(--accent);
      letter-spacing: 0.15em;
      text-transform: uppercase;
      margin-bottom: 0.4rem;
    }
    .timeline-title { font-size: 1.05rem; font-weight: 700; margin-bottom: 0.5rem; }
    .timeline-body { font-size: 0.88rem; color: var(--muted); line-height: 1.7; }
    .cert-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-top: 2rem; }
    .cert-card {
      padding: 1.2rem;
      text-align: center;
      border: 1px solid var(--border);
      background: var(--card);
      border-radius: 4px;
      font-size: 0.82rem;
    }
    .cert-icon { font-size: 1.8rem; margin-bottom: 0.5rem; }
    .cert-name { font-weight: 700; font-size: 0.88rem; margin-bottom: 0.25rem; }
    .cert-timeline { font-family: 'Space Mono', monospace; font-size: 0.7rem; color: var(--accent); }

    /* === EVIDENCE SECTION === */
    .evidence-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
    .evidence-card { position: relative; overflow: hidden; }
    .evidence-card .e-type {
      font-family: 'Space Mono', monospace;
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent2);
      margin-bottom: 0.5rem;
    }
    .evidence-card h4 { font-size: 1rem; margin-bottom: 0.5rem; }
    .evidence-card p { font-size: 0.85rem; color: var(--muted); }
    .placeholder-note {
      margin-top: 1rem;
      padding: 0.6rem 1rem;
      background: rgba(255,64,129,0.08);
      border-left: 2px solid var(--accent2);
      font-size: 0.8rem;
      color: var(--accent2);
      font-family: 'Space Mono', monospace;
    }

    /* === REFLECTION === */
    .google-header {
      display: flex;
      align-items: center;
      gap: 1.5rem;
      margin-bottom: 3rem;
      padding: 2rem;
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 4px;
    }
    .google-logo {
      font-size: 2.5rem;
      font-weight: 800;
      letter-spacing: -0.05em;
    }
    .g { color: #4285F4; }
    .o1 { color: #EA4335; }
    .o2 { color: #FBBC04; }
    .g2 { color: #4285F4; }
    .l { color: #34A853; }
    .e { color: #EA4335; }
    .google-info h3 { font-size: 1.2rem; font-weight: 700; }
    .google-info p { color: var(--muted); font-size: 0.88rem; }
    .reflection-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
    .reflection-q {
      font-family: 'Space Mono', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.75rem;
    }
    .reflection-a { font-size: 0.9rem; color: var(--muted); line-height: 1.8; }
    .sw-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 1rem; }
    .sw-box { padding: 1.2rem; border-radius: 3px; font-size: 0.85rem; }
    .sw-box.strength { background: rgba(105,255,71,0.06); border: 1px solid rgba(105,255,71,0.15); }
    .sw-box.weakness { background: rgba(255,64,129,0.06); border: 1px solid rgba(255,64,129,0.15); }
    .sw-label { font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase; font-family: 'Space Mono', monospace; margin-bottom: 0.5rem; }
    .sw-box.strength .sw-label { color: var(--accent3); }
    .sw-box.weakness .sw-label { color: var(--accent2); }
    ul.sw-list { list-style: none; }
    ul.sw-list li { color: var(--muted); font-size: 0.85rem; padding: 0.2rem 0; }

    /* === FOOTER === */
    footer {
      text-align: center;
      padding: 3rem 2rem;
      border-top: 1px solid var(--border);
      font-family: 'Space Mono', monospace;
      font-size: 0.75rem;
      color: var(--muted);
      position: relative;
      z-index: 1;
    }
    footer span { color: var(--accent); }

    /* === ANIMATIONS === */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .reveal {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.7s ease, transform 0.7s ease;
    }
    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* === DIVIDER === */
    .section-divider {
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--border), transparent);
      max-width: 1100px;
      margin: 0 auto;
    }

    @media (max-width: 768px) {
      .career-main, .career-grid, .skills-grid, .cert-grid, .evidence-grid, .reflection-grid, .sw-grid { grid-template-columns: 1fr; }
      .career-main { grid-template-columns: 1fr; }
      nav { padding: 0 1rem; }
      .nav-links { gap: 1rem; }
    }
  </style>
</head>
